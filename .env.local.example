# ================================================================
# FiTDOOR Trainer App — 환경변수 설정 가이드
# cp .env.local.example .env.local 후 값을 채워주세요
# ⚠️  .env.local은 절대 git에 커밋하지 마세요
# ================================================================

# ─── Supabase (서버 전용 — NEXT_PUBLIC_ 최소화) ───────────────────
# Supabase 대시보드 > Settings > API에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service Role Key는 절대 클라이언트에 노출 금지
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── NextAuth ─────────────────────────────────────────────────────
# 랜덤 시크릿 생성: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000
# 운영 환경:
# NEXTAUTH_URL=https://your-domain.com

# ─── Google OAuth 2.0 ─────────────────────────────────────────────
# Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── 암호화 키 (서버 전용 — 절대 NEXT_PUBLIC_ 붙이지 말 것) ──────
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-key-here

# ─── 해시 솔트 (서버 전용) ────────────────────────────────────────
HASH_SALT=your-random-hash-salt

# ─── 앱 URL ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── 광고 설정 ───────────────────────────────────────────────────
# internal: ad_banners 테이블 광고 (개발/MVP)
# adsense:  Google AdSense (배포 후)
NEXT_PUBLIC_AD_MODE=internal

# Google AdSense (NEXT_PUBLIC_AD_MODE=adsense 시 필요)
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT=XXXXXXXXXX

# ─── Phase 2 (현재 미사용) ────────────────────────────────────────
# NEXT_PUBLIC_ENABLE_PHASE2=false
